Subject: [PATCH 4/4] win32u: Call SetIMEEnabled from
 NtUserAssociateInputContext.

---
 dlls/win32u/imm.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/dlls/win32u/imm.c b/dlls/win32u/imm.c
index 1c1cad94b3f..95209686c06 100644
--- a/dlls/win32u/imm.c
+++ b/dlls/win32u/imm.c
@@ -220,6 +220,9 @@ UINT WINAPI NtUserAssociateInputContext( HWND hwnd, HIMC ctx, ULONG flags )
     }
 
     release_win_ptr( win );
+
+    user_driver->pSetIMEEnabled( hwnd, ctx != NULL );
+
     return ret;
 }
 
