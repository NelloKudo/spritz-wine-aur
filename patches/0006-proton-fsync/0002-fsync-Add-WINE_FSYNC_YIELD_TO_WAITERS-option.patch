From 7dc421dd4c5db1a74d684fbde831b9ef5c9a45bb Mon Sep 17 00:00:00 2001
From: Paul Gofman <pgofman@codeweavers.com>
Date: Thu, 27 Apr 2023 17:32:38 -0600
Subject: [PATCH 2/6] fsync: Add WINE_FSYNC_YIELD_TO_WAITERS option.

CW-Bug-Id: #22194
---
 dlls/ntdll/unix/env.c          | 7 +++++++
 dlls/ntdll/unix/unix_private.h | 1 +
 2 files changed, 8 insertions(+)

diff --git a/dlls/ntdll/unix/env.c b/dlls/ntdll/unix/env.c
index 7d4ca20ad4b..9cfd91f5385 100644
--- a/dlls/ntdll/unix/env.c
+++ b/dlls/ntdll/unix/env.c
@@ -75,6 +75,7 @@ int main_argc = 0;
 char **main_argv = NULL;
 WCHAR **main_wargv = NULL;
 BOOL fsync_simulate_sched_quantum = FALSE;
+BOOL fsync_yield_to_waiters = FALSE;
 
 static LCID user_lcid, system_lcid;
 static LANGID user_ui_language;
@@ -842,6 +843,12 @@ void init_environment(void)
         fsync_simulate_sched_quantum = !!strstr( main_argv[1], "Ubisoft Game Launcher\\upc.exe" );
     if (fsync_simulate_sched_quantum)
         ERR( "HACK: Simulating sched quantum in fsync.\n" );
+
+    env_str = getenv( "WINE_FSYNC_YIELD_TO_WAITERS" );
+    if (env_str)
+        fsync_yield_to_waiters = !!atoi( env_str );
+    if (fsync_yield_to_waiters)
+        ERR( "HACK: fsync: yield to waiters.\n" );
 }
 
 
diff --git a/dlls/ntdll/unix/unix_private.h b/dlls/ntdll/unix/unix_private.h
index e67a0ba1ef6..3b3cb7c6d87 100644
--- a/dlls/ntdll/unix/unix_private.h
+++ b/dlls/ntdll/unix/unix_private.h
@@ -206,6 +206,7 @@ extern int main_argc;
 extern char **main_argv;
 extern WCHAR **main_wargv;
 extern BOOL fsync_simulate_sched_quantum;
+extern BOOL fsync_yield_to_waiters;
 extern const WCHAR system_dir[];
 extern unsigned int supported_machines_count;
 extern USHORT supported_machines[8];
-- 
2.53.0

